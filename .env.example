PORT=3000
VITE_APP_MODE=cloud
IMAGE_DIR=/srv/whiteboard/images
# Local development can omit this; the backend defaults to .whiteboard-uploads.
# On a cloud server, set this to /srv/whiteboard/uploads.
UPLOAD_DIR=/srv/whiteboard/uploads
MAX_UPLOAD_FILES=50
MAX_UPLOAD_FILE_BYTES=10485760
MAX_UPLOAD_TOTAL_BYTES=104857600
UPLOAD_TTL_HOURS=24

AI_BASE_URL=https://api.apiyi.com/v1
YI_API_KEY=你的密钥
OPENAI_MODEL=gpt-4.1-mini
GEOMETRY_MODEL=gpt-4.1-mini
AI_REQUEST_TIMEOUT_MS=240000

# Optional. Enable this on a public server to prevent unlimited API usage.
BASIC_AUTH_USER=whiteboard
BASIC_AUTH_PASSWORD=change-this-password
